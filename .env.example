APP_NAME=taskrit-chat
NODE_ENV=development
UPLOAD_DIR=uploads

# Chat DB (environment-specific)
MONGODB_URI_LOCAL=mongodb://localhost:27017
MONGODB_DB_LOCAL=taskrit-chat
MONGODB_URI_PROD=mongodb://mongodb:27017
MONGODB_DB_PROD=taskrit-chat

# Main backend user-auth endpoint (environment-specific)
USER_API_BASE_URL_LOCAL=http://localhost:3000
USER_API_BASE_URL_PROD=https://api.taskr.it
USER_ME_ENDPOINT=/user/me
